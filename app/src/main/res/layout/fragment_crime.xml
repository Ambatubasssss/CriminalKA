<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top card: photo, camera button bottom-right -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_list_item_card">

            <ImageView
                android:id="@+id/crime_photo"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:contentDescription="@string/crime_photo_no_image_description"
                android:scaleType="centerCrop" />

            <ImageButton
                android:id="@+id/crime_camera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/crime_camera"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="@color/primary" />
        </FrameLayout>

        <!-- Title section -->
        <TextView
            android:id="@+id/crime_title_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_section"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <EditText
            android:id="@+id/crime_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@color/surface"
            android:hint="@string/crime_title_hint"
            android:importantForAutofill="no"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp" />

        <!-- Date and Solved in one row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/crime_date_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/details_section"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/crime_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                style="@style/Widget.CriminalIntent.Button.Secondary" />

            <CheckBox
                android:id="@+id/crime_solved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crime_solved"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/divider" />

        <!-- Suspect row: label left, Assign Police button RIGHT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/crime_suspect_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SUSPECT"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/assign_police_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASSIGN POLICE"
                style="@style/Widget.CriminalIntent.Button.Secondary" />
        </LinearLayout>

        <EditText
            android:id="@+id/crime_suspect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/surface"
            android:hint="Enter suspect name"
            android:importantForAutofill="no"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/choose_suspect_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHOOSE SUSPECT"
                style="@style/Widget.CriminalIntent.Button.Secondary" />

            <Button
                android:id="@+id/call_suspect_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="CALL SUSPECT"
                style="@style/Widget.CriminalIntent.Button.Secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/police_info_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POLICE NAME"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/police_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@color/surface"
                android:hint="Enter officer name"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="POLICE CONTACT"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/police_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@color/surface"
                android:hint="Enter officer contact"
                android:inputType="phone"
                android:maxLines="1"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />
        </LinearLayout>

        <!-- Bottom action buttons: side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/crime_report"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/send_report" />

            <Button
                android:id="@+id/contact_police_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                style="@style/Widget.CriminalIntent.Button.Secondary"
                android:text="@string/contact_police" />
        </LinearLayout>

        <Button
            android:id="@+id/crime_add"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/add_crime"
            android:visibility="gone"
            style="@style/Widget.CriminalIntent.Button.Secondary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
